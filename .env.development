# Backend URL for `npm run dev`. Empty = offline: community section is read-only
# from the local cache, creation shows "Serveur non configuré" — dev never hits prod.
VITE_COMMUNITY_API=http://localhost:8787

# To develop against a LOCAL Worker instead, run `wrangler dev` in server/ (serves
# http://localhost:8787) and use that here:
# VITE_COMMUNITY_API=http://localhost:8787
